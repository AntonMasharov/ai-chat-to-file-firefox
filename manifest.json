{
  "manifest_version": 2,
  "name": "AI Chat to pdf, txt",
  "version": "1.0.0",
  "description": "Export AI chat conversations (Claude, ChatGPT, Gemini) to a file",
  "author": "You",
  "icons": {
    "48": "icons/icon48.png",
    "96": "icons/icon96.png"
  },
  "browser_action": {
    "default_icon": "icons/icon48.png",
    "default_title": "AI Chat to pdf, txt",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "*://claude.ai/*",
        "*://chatgpt.com/*",
        "*://chat.openai.com/*",
        "*://gemini.google.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "permissions": ["activeTab", "tabs", "downloads"],
  "web_accessible_resources": ["print.html"]
}
